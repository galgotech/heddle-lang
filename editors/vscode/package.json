{
  "name": "heddle-language",
  "displayName": "Heddle Language",
  "description": "Language support for the heddle language",
  "publisher": "galgotech",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Data Science",
    "Formatters",
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "data tools",
    "functional programming",
    "workflow",
    "pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/galgotech/heddle-vscode.git"
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  },
  "contributes": {
    "commands": [
      {
        "command": "heddle.runFile",
        "title": "Run Heddle File",
        "icon": "$(play)"
      },
      {
        "command": "heddle.startControlPlane",
        "title": "Start Control Plane",
        "icon": "$(play)"
      },
      {
        "command": "heddle.stopControlPlane",
        "title": "Stop Control Plane",
        "icon": "$(primitive-square)"
      },
      {
        "command": "heddle.restartControlPlane",
        "title": "Restart Control Plane",
        "icon": "$(refresh)"
      },
      {
        "command": "heddle.addPluginFolder",
        "title": "Add Plugin Folder",
        "icon": "$(add)"
      },
      {
        "command": "heddle.startPlugin",
        "title": "Start Plugin",
        "icon": "$(play)"
      },
      {
        "command": "heddle.stopPlugin",
        "title": "Stop Plugin",
        "icon": "$(primitive-square)"
      },
      {
        "command": "heddle.restartPlugin",
        "title": "Restart Plugin",
        "icon": "$(refresh)"
      },
      {
        "command": "heddle.editPluginSource",
        "title": "Edit Heddle SDK Plugin Source"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "heddle-explorer",
          "title": "Heddle",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "heddle-explorer": [
        {
          "id": "heddle-control-plane",
          "name": "Control Plane Manager"
        },
        {
          "id": "heddle-sdk-plugins",
          "name": "SDK Plugin Manager"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "heddle.runFile",
          "when": "resourceLangId == heddle",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "heddle.addPluginFolder",
          "when": "view == heddle-sdk-plugins",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "heddle.startControlPlane",
          "when": "view == heddle-control-plane && viewItem == controlPlaneStopped",
          "group": "inline"
        },
        {
          "command": "heddle.stopControlPlane",
          "when": "view == heddle-control-plane && viewItem == controlPlaneRunning",
          "group": "inline"
        },
        {
          "command": "heddle.restartControlPlane",
          "when": "view == heddle-control-plane && viewItem == controlPlaneRunning",
          "group": "inline"
        },
        {
          "command": "heddle.startPlugin",
          "when": "view == heddle-sdk-plugins && viewItem == pluginStopped",
          "group": "inline"
        },
        {
          "command": "heddle.stopPlugin",
          "when": "view == heddle-sdk-plugins && viewItem == pluginRunning",
          "group": "inline"
        },
        {
          "command": "heddle.restartPlugin",
          "when": "view == heddle-sdk-plugins && viewItem == pluginRunning",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "heddle.editPluginSource",
          "when": "explorerResourceIsFolder",
          "group": "7_modification"
        }
      ]
    },
    "languages": [
      {
        "id": "heddle",
        "aliases": [
          "Heddle",
          "heddle",
          "he"
        ],
        "extensions": [
          ".he"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Heddle",
      "properties": {
        "heddle.path": {
          "type": "string",
          "default": "",
          "description": "Optional: Custom path to the heddle CLI binary."
        },
        "heddle.lspPath": {
          "type": "string",
          "default": "",
          "description": "Optional: Custom path to the heddle LSP binary (if you want to override heddle.path)."
        },
        "heddle.controlPlaneAddr": {
          "type": "string",
          "default": "localhost:50051",
          "description": "The address of the Heddle Control Plane."
        }
      }
    },
    "debuggers": [
      {
        "type": "heddle-debug",
        "label": "Heddle Debugger",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .he file to debug",
                "default": "${workspaceFolder}/main.he"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "heddle-debug",
            "request": "launch",
            "name": "Debug Heddle File",
            "program": "${file}"
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "heddle"
      }
    ],
    "keybindings": [
      {
        "command": "workbench.action.debug.stepOver",
        "key": "f11",
        "when": "debugType == 'heddle-debug'"
      },
      {
        "command": "workbench.action.debug.stepOver",
        "key": "shift+f11",
        "when": "debugType == 'heddle-debug'"
      }
    ],
    "grammars": [
      {
        "language": "heddle",
        "scopeName": "source.heddle",
        "path": "./syntaxes/heddle.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[heddle]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.formatOnType": true,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.7.1",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}